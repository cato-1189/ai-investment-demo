{
  "title": "Decision agent output phase2.v1",
  "type": "object",
  "required": [
    "as_of_date",
    "ticker",
    "company",
    "decision",
    "conviction",
    "suggested_weight",
    "max_acceptable_weight",
    "time_horizon_months",
    "reason_for_decision",
    "key_risks",
    "invalidation_triggers",
    "monitoring_conditions",
    "data_quality",
    "research_quality",
    "requires_audit"
  ],
  "properties": {
    "as_of_date": {
      "type": "string",
      "minLength": 1
    },
    "ticker": {
      "type": "string",
      "minLength": 1
    },
    "company": {
      "type": "string",
      "minLength": 1
    },
    "decision": {
      "type": "string",
      "enum": [
        "BUY_DEMO",
        "DO_NOT_BUY",
        "HOLD_DEMO",
        "REDUCE_DEMO",
        "SELL_DEMO",
        "WATCHLIST",
        "NEED_MORE_DATA"
      ]
    },
    "conviction": {
      "type": "string",
      "enum": [
        "HIGH",
        "MEDIUM",
        "LOW"
      ]
    },
    "suggested_weight": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "max_acceptable_weight": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "time_horizon_months": {
      "type": "number"
    },
    "base_case_upside": {
      "type": [
        "number",
        "null"
      ]
    },
    "bull_case_upside": {
      "type": [
        "number",
        "null"
      ]
    },
    "bear_case_downside": {
      "type": [
        "number",
        "null"
      ]
    },
    "upside_downside_ratio": {
      "type": [
        "number",
        "null"
      ]
    },
    "main_thesis": {
      "type": "string",
      "minLength": 1
    },
    "main_catalyst": {
      "type": "string",
      "minLength": 1
    },
    "reason_for_decision": {
      "type": "string",
      "minLength": 1
    },
    "key_risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "invalidation_triggers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "monitoring_conditions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "data_quality": {
      "type": "string",
      "enum": [
        "HIGH",
        "MEDIUM",
        "LOW"
      ]
    },
    "research_quality": {
      "type": "string",
      "enum": [
        "HIGH",
        "MEDIUM",
        "LOW"
      ]
    },
    "requires_audit": {
      "type": "boolean"
    }
  }
}
